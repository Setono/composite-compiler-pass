{
    "name": "setono/composite-compiler-pass",
    "description": "A composite compiler pass for Symfony to make it even easier to create composite services",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Joachim Løvgaard",
            "email": "joachim@loevgaard.dk"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/dependency-injection": "^6.4 || ^7.4 || ^8.0"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.52",
        "infection/infection": "^0.29.8",
        "matthiasnoback/symfony-dependency-injection-test": "^4.3",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^10.5",
        "sylius-labs/coding-standard": "^4.5"
    },
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Setono\\CompositeCompilerPass\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Setono\\CompositeCompilerPass\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": false,
            "ergebnis/composer-normalize": true,
            "infection/extension-installer": true,
            "phpstan/extension-installer": true
        },
        "platform": {
            "php": "8.1.99"
        },
        "sort-packages": true
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "check-style": "ecs check",
        "fix-style": "ecs check --fix",
        "phpunit": "phpunit"
    }
}
